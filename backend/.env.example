# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Document ingestion
DOCS_FOLDER_PATH=/path/to/your/docs/folder

# Admin stop endpoint
ADMIN_TOKEN=change-me-to-a-strong-secret

# Server
HOST=0.0.0.0
PORT=8000

# ChromaDB (local persistence)
CHROMA_PERSIST_DIR=./chroma_db

# SQLite
DATABASE_URL=sqlite:///./vizor_chat.db

# Cache TTL in seconds (how long to cache repeated questions)
CACHE_TTL=300
